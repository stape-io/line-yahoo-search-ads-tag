setup: |-
  const JSON = require('JSON');
  const Promise = require('Promise');
  const callLater = require('callLater');

  function assign() {
    const target = arguments[0];
    for (let i = 1; i < arguments.length; i++) {
      for (let key in arguments[i]) {
        target[key] = arguments[i][key];
      }
    }
    return target;
  }

  function createMockData() {
    return {
      // Base config
      appId: 'AfSF9A9FaskASD9koa',
      conversionId: '1234567890',
      conversionLabel: 'a1B2C3dE4FgH5IJK6_lMno7',
      useOptimisticScenario: false,

      // Click ID cookie settings
      setClickIdCookie: true,
      cookieDomain: 'auto',
      cookieSameSite: 'none',
      cookieHttpOnly: false,
      cookieExpiration: 90,

      // Server event data
      autoMapServerEventDataParameters: true,
      serverEventDataList: undefined,

      // User identifiers
      autoMapUserIdentifiersParameters: true,
      userIdentifiersParametersList: undefined,

      // Web parameters
      autoMapWebParameters: true,
      webParametersList: undefined,

      // Event parameters
      autoMapEventParameters: true,
      eventParametersList: undefined,

      // Consent
      adStorageConsent: 'optional'
    };
  }

  function createEventData() {
    return {
      page_location: 'https://example.com/page1?yclid=YSS.default-yclid',
      page_referrer: 'https://ref.example.com/',
      ip_override: '192.168.0.1',
      user_agent: 'Mozilla/5.0 test-agent'
    };
  }

  // ---------------------------------------------------------------------------
  // Default event data satisfies the "no early-exit" and "no-validation-error" path:
  //   - has a page_location that is NOT the GTM preview endpoint
  //   - provides a yclid (via URL query) so click id validation always passes
  //   - provides ip_override and user_agent so those validators always pass
  // ---------------------------------------------------------------------------
  mock('getAllEventData', createEventData);

  // Default: no _ly_sa_cids cookie found
  mock('getCookieValues', () => []);

  // Default: no request headers set (referer, trace-id, etc.)
  mock('getRequestHeader', () => undefined);

  // Default: deterministic eTLD+1 domain resolution for "auto" cookie domain
  mock('computeEffectiveTldPlusOne', (domainOrUrl) => 'example.com');

  // Default: setCookie is a no-op unless overridden in a specific test
  mock('setCookie', () => {});

  const NOW_MILLISECONDS = 1753421286937;
  mock('getTimestampMillis', NOW_MILLISECONDS);

  // ---------------------------------------------------------------------------
  // Minimal mockData satisfying all required field validators via auto-mapping
  // ---------------------------------------------------------------------------
  const mockData = createMockData();


